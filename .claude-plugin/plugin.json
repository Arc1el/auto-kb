{
  "name": "auto-kb",
  "version": "3.0.0",
  "description": "Automatically logs Claude Code sessions per project and delegates KB documentation to the background-secretary subagent, writing directly to Obsidian vault.",
  "author": {
    "name": "jayden"
  },
  "repository": "https://github.com/Arc1el/auto-kb",
  "license": "MIT",
  "keywords": ["knowledge-base", "session-log", "automation", "obsidian", "documentation", "subagent"],
  "agents": "./agents/",
  "skills": ["skills/auto-kb", "skills/obsidian-cli", "skills/obsidian-markdown"],
  "commands": ["commands/setup.md", "commands/kb-sync.md", "commands/blog.md"],
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/auto_kb_hook.sh"
          }
        ]
      }
    ]
  }
}
